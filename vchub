<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VinuChain Ecosystem</title>
    <link rel="icon" href="https://photos.pinksale.finance/file/pinksale-logo-upload/1759847695513-f915ce15471ce09f03d8fbf68bc0616f.png" type="image/png">
    <style>
        :root {
            --bg: #000;
            --fg: #fff;
            --card: #111;
            --border: #222;
            --accent: #ccc;
            --shadow: 0 8px 30px rgba(255,255,255,0.06);
            --radius: 20px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--fg);
            line-height: 1.7;
        }
        header {
            padding: 1.5rem 1.2rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: flex-start;
        }
        .logo {
            height: 46px;
            border-radius: 10px;
            transition: transform 0.3s ease;
        }
        .logo:hover { transform: scale(1.06); }
        .hero {
            text-align: center;
            padding: 4rem 1rem;
            max-width: 900px;
            margin: 0 auto;
        }
        .hero h1 {
            font-size: clamp(2.8rem, 6vw, 4.5rem);
            font-weight: 800;
            letter-spacing: -0.8px;
            margin-bottom: 1rem;
        }
        .hero p {
            font-size: 1.2rem;
            opacity: 0.9;
        }
        nav {
            background: var(--border);
            padding: 1.2rem;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 1rem;
            border-radius: var(--radius);
            margin: 0 1rem 2rem;
        }
        .tab-btn {
            background: none;
            border: 1.5px solid var(--accent);
            color: var(--fg);
            padding: 0.85rem 1.6rem;
            cursor: pointer;
            font-weight: 600;
            border-radius: 50px;
            font-size: 0.98rem;
            min-width: 110px;
            transition: all 0.3s ease;
        }
        .tab-btn.active, .tab-btn:hover {
            background: var(--fg);
            color: var(--bg);
            box-shadow: var(--shadow);
        }
        .container { max-width: 1300px; margin: 0 auto; padding: 1rem; }
        .search {
            width: 100%; max-width: 500px; margin: 2rem auto; display: block;
            padding: 1.1rem; border: 1.5px solid var(--border); background: var(--bg);
            color: var(--fg); font-size: 1.05rem; border-radius: 50px; text-align: center;
            transition: border-color 0.3s ease;
        }
        .search:focus { outline: none; border-color: var(--accent); }
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.8rem;
            margin-top: 1.5rem;
        }
        .project-card {
            background: var(--card);
            border-radius: var(--radius);
            padding: 2.2rem;
            text-align: center;
            position: relative;
            border: 1px solid var(--border);
            opacity: 0;
            transform: translateY(30px);
            animation: smoothFadeIn 0.7s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
        }
        .project-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow);
            border-color: var(--accent);
            transition: all 0.3s ease;
        }
        @keyframes smoothFadeIn {
            to { opacity: 1; transform: translateY(0); }
        }
        .project-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
            background: linear-gradient(90deg, var(--accent), transparent);
        }
        .live-badge {
            position: absolute; top: 1rem; left: 1rem;
            background: #00bfff; color: #000; padding: 0.4rem 0.9rem;
            font-weight: 600; border-radius: 20px; font-size: 0.75rem;
        }
        .icon {
            width: 48px; height: 48px; margin: 0 auto 1rem;
            fill: var(--fg); opacity: 0.85;
        }
        .project-name {
            font-size: 1.45rem; font-weight: 700; margin-bottom: 0.6rem;
        }
        .project-desc {
            opacity: 0.8; font-size: 0.98rem; margin-bottom: 1.2rem;
        }
        .project-links {
            display: flex; gap: 0.9rem; justify-content: center; flex-wrap: wrap;
        }
        .btn {
            padding: 0.7rem 1.4rem; border: 1.5px solid var(--accent);
            background: none; color: var(--fg); text-decoration: none;
            border-radius: 30px; font-weight: 600; font-size: 0.92rem;
            transition: all 0.3s ease;
        }
        .btn:hover { background: var(--fg); color: var(--bg); }
        .coming-soon {
            grid-column: 1 / -1; padding: 4rem 2rem; text-align: center;
        }
        .coming-soon h3 { font-size: 1.9rem; margin-bottom: 1rem; opacity: 0.9; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        footer {
            background: var(--border); text-align: center; padding: 2.5rem;
            margin-top: 5rem; font-size: 0.92rem; opacity: 0.75;
        }
        @media (max-width: 768px) {
            .hero { padding: 3rem 1rem; }
            .hero h1 { font-size: 2.7rem; }
            .tab-btn { padding: 0.7rem 1.2rem; font-size: 0.9rem; }
            .project-card { padding: 1.9rem; }
            .icon { width: 40px; height: 40px; }
        }
        @media (max-width: 480px) {
            .projects-grid { grid-template-columns: 1fr; }
            nav { flex-direction: column; align-items: center; }
            .tab-btn { width: 85%; }
        }
    </style>
